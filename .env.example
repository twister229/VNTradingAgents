# =====================================================================
# TradingAgents — Vietnamese Market Edition
# Market data comes from vnstock (no API key). You only need ONE LLM key.
# =====================================================================

# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
DASHSCOPE_CN_API_KEY=
ZHIPU_API_KEY=
ZHIPU_CN_API_KEY=
MINIMAX_API_KEY=
MINIMAX_CN_API_KEY=
OPENROUTER_API_KEY=

# NOTE: No market-data API key is required. This edition fetches prices,
# fundamentals, and company news for Vietnamese tickers through vnstock (VCI
# source). Yahoo Finance / Alpha Vantage are not used on the VN path.

# Optional: point at a remote Ollama server. When unset, defaults to
# the local instance at http://localhost:11434/v1.
#OLLAMA_BASE_URL=http://your-ollama-host:11434/v1

# Optional: override DEFAULT_CONFIG without editing code.
# Any TRADINGAGENTS_* variable below, when set, replaces the matching key
# in tradingagents/default_config.py. Values are coerced to the type of
# the existing default (bool / int / str), so "true"/"3" work as expected.
#TRADINGAGENTS_LLM_PROVIDER=openai
#TRADINGAGENTS_DEEP_THINK_LLM=gpt-5.5
#TRADINGAGENTS_QUICK_THINK_LLM=gpt-5.4-mini
#TRADINGAGENTS_LLM_BACKEND_URL=

# Vietnamese-market defaults (already the defaults in code; shown here so they
# are easy to find / override).
#TRADINGAGENTS_MARKET=VN                  # VN selects vnstock + VN symbol rules
#TRADINGAGENTS_OUTPUT_LANGUAGE=Vietnamese # final reports language

# Reproducible research: freeze vnstock fundamentals + news to disk so repeat
# runs of the same ticker/date see identical inputs. Off by default (live runs
# stay fresh). OHLCV is always cached separately.
#TRADINGAGENTS_VNSTOCK_CACHE=false

#TRADINGAGENTS_MAX_DEBATE_ROUNDS=1
#TRADINGAGENTS_MAX_RISK_ROUNDS=1
#TRADINGAGENTS_CHECKPOINT_ENABLED=false
# Sampling temperature (lower = less run-to-run variation on models that
# honor it). Unset leaves each provider at its default. See the README
# "Reproducibility" note — no setting makes LLM output fully deterministic.
#TRADINGAGENTS_TEMPERATURE=0.0
